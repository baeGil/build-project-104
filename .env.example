# Groq API
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_PRIMARY=llama-3.1-8b-instant
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legal_docs

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=legal_docs
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j (Phase 2)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Embedding Model
EMBEDDING_MODEL=Quockhanh05/Vietnam_legal_embeddings
EMBEDDING_DIM=768

# HuggingFace Configuration (Optional)
# If you're in Asia or having connectivity issues to huggingface.co,
# uncomment the line below to use a mirror:
# HF_ENDPOINT=https://hf-mirror.com

# HuggingFace Hub Timeouts (seconds)
# Increase these if you're on a slow network or behind a proxy
# HF_HUB_ETAG_TIMEOUT=300
# HF_HUB_DOWNLOAD_TIMEOUT=600

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=info
